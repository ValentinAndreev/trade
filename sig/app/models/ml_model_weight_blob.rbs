class MlModelWeightBlob < ApplicationRecord
  MAX_BYTE_SIZE: Integer
  BASELINE_FORMAT: String
  SUPPORTED_FORMATS: Array[String]
  ADAPTER_SCHEMA_VERSION: String

  attr_accessor weights_format: String
  attr_accessor weights_payload: String
  attr_accessor byte_size: Integer
  attr_accessor checksum: String

  def self.checksum_for: (training_run: MlTrainingRun, weights_format: String, weights_payload: String) -> String

  def payload_bytes: () -> Integer

  private def self.canonical_snapshot_json: (training_run: MlTrainingRun, weights_format: String, weights_payload: String) -> String
  private def self.deep_sort: (untyped value) -> untyped

  private

  def sync_byte_size: () -> void
  def byte_size_matches_payload: () -> void
end
