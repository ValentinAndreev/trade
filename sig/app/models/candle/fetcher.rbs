class Candle
  class Fetcher
    MAX_LIMIT: Integer
    RECENT_LIMIT: Integer
    MAX_ATTEMPTS: Integer
    SYMBOL_PREFIX: String
    EXCHANGE: String
    HISTORY_START_MS: Integer
    CONTINUOUS_AGGREGATE_BUCKETS: Hash[String, untyped]

    class FetchError < StandardError
    end

    attr_reader client: Utils::BitfinexClient
    attr_reader symbol: String
    attr_reader interval: String
    attr_reader load_all_data: bool
    attr_reader connection: untyped

    def initialize: (String symbol, ?interval: String, ?load_all_data: bool) -> void
    def call: () -> void

    private

    def sync_recent: () -> void
    def gap_minutes: () -> Integer?
    def fetch_and_upsert: (Integer limit) -> void
    def paginate_history: () -> void
    def history_start_ms: () -> Integer?
    def paginate_backward: (from: Integer?, ?refresh_aggregates: bool, ?invalidate_min: bool) -> void
    def import_and_broadcast: (Array[Hash[Symbol, untyped]] records, ?broadcast: bool) -> Array[untyped]
    def next_page_ms: (untyped oldest_ts) -> Integer?
    def current_time_ms: () -> Integer
    def fetch_candles: (end_time: Integer, ?limit: Integer, ?attempt: Integer) -> Array[Array[Numeric]]
    def build_records: (Array[Array[Numeric]] data) -> Array[Hash[Symbol, untyped]]
    def broadcast_candles: (Array[Hash[Symbol, untyped]] records) -> void
    def invalidate_cache: (Symbol kind) -> void
    def retry_pause: () -> Numeric
    def refresh_continuous_aggregates: (Array[Time] imported_timestamps) -> void
  end
end
