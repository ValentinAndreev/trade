module Api
  class ResearchController < ApplicationController
    def catalog: () -> void
    def editor_metadata: () -> void
    def cancel: () -> void
    def validate: () -> void
    def save_system: () -> void
    def rename_system: () -> void
    def delete_system: () -> void
    def create_directory: () -> void
    def rename_directory: () -> void
    def delete_directory: () -> void
    def run: () -> void

    private

    def monotonic_now: () -> Float
    def elapsed_ms: (Float started_at) -> Float
    def research_payload: () -> Hash[Symbol, untyped]
    def missing_yaml_response: () -> Hash[Symbol, untyped]
  end
end
