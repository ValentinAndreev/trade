module Api
  module Ml
    class ModelsController < Api::ApplicationController
      MAX_LIMIT: Integer

      def index: () -> void
      def autocomplete: () -> void

      private

      def requested_limit: () -> Integer
      def active_training_runs_by_model_id: (Array[MlModel] models) -> Hash[Integer, MlTrainingRun]
      def serialize_model: (MlModel model, active_training_run: MlTrainingRun?) -> Hash[Symbol, untyped]
      def serialize_autocomplete_model: (MlModel model) -> Hash[Symbol, untyped]
      def serialize_run_summary: (MlTrainingRun? training_run) -> Hash[Symbol, untyped]?
    end
  end
end
