module Api
  class AssistantChatsController < ApplicationController
    @chat: AiChat

    def index: () -> void
    def create: () -> void
    def show: () -> void
    def update: () -> void
    def destroy: () -> void
    def create_message: () -> void

    private

    def set_chat: () -> void
    def assistant_context_params: () -> Hash[Symbol, untyped]
    def llm_setting_configured?: (LlmSetting? setting) -> bool
    def chat_payload: (AiChat chat) -> Hash[Symbol, untyped]
  end
end
