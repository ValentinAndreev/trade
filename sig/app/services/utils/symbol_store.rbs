module Utils
  class SymbolStore
    def self.current_path: () -> Pathname
    def self.dashboard_symbols: () -> Array[String]
    def self.save_dashboard_symbols: (Array[String] symbols) -> void
    def self.add_dashboard_symbol: (String symbol) -> Array[String]
    def self.remove_dashboard_symbol: (String symbol) -> Array[String]

    def self.market_symbols: () -> market_symbols
    def self.save_market_symbols: (market_symbols symbols) -> void
    def self.add_market_symbol: (String category, String symbol) -> market_symbols
    def self.remove_market_symbol: (String category, String symbol) -> market_symbols

    def self.reset!: () -> void
    def self.snapshot: () -> symbol_snapshot
    def self.restore!: (?dashboard_symbols: Array[String]?, ?market_symbols: Hash[String, Array[String]]?) -> void
  end
end
