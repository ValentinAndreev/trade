class Candle
  class TickerQuery
    SPARKLINE_POINTS: Integer
    TICKERS_CACHE_KEY_PREFIX: String
    TICKERS_CACHE_TTL: untyped
    SPARKLINE_CACHE_TTL: untyped
    IDX_SYMBOL: Integer
    IDX_DAILY_CHANGE: Integer
    IDX_DAILY_CHANGE_PC: Integer
    IDX_LAST_PRICE: Integer
    IDX_VOLUME: Integer
    IDX_HIGH: Integer
    IDX_LOW: Integer

    @symbols: Array[String]

    def initialize: (Array[String] symbols) -> void
    def call: () -> Array[ticker_data]

    private

    def fetch_live_tickers: () -> Hash[String, candle_live_ticker]
    def parse_tickers: (Array[Array[untyped]] raw) -> Hash[String, candle_live_ticker]
    def tickers_cache_key: () -> String
    def fetch_all_sparklines: () -> Hash[String, Array[Float]]
    def build_ticker: (String symbol, candle_live_ticker? live, Array[Float] sparkline) -> ticker_data?
    def build_ticker_from_db: (String symbol, Array[Float] sparkline) -> ticker_data?
    def sample_sparkline: (Array[Float] closes) -> Array[Float]
  end
end
