module Research
  module Modules
    class MlSignal < CandleAligned
      NUMERIC_OUTPUTS: Array[String]
      @warmup_candle_cache: Hash[untyped, Array[ohlcv]]

      class Error < StandardError
        attr_reader code: Symbol
        attr_reader details: Hash[Symbol, untyped]

        def initialize: (String message, code: Symbol, ?details: Hash[Symbol, untyped]) -> void
      end

      def initialize: (
        candles: Array[ohlcv],
        ?symbol: String?,
        ?timeframe: String?,
        ?exchange: String,
        ?start_time: String | Time?,
        ?end_time: String | Time?
      ) -> void

      def call: (
        model_key: String,
        ?output: String,
        ?cancel_check: untyped,
        **untyped
      ) -> Array[research_module_point]

      private

      attr_reader symbol: String?
      attr_reader timeframe: String?
      attr_reader exchange: String
      attr_reader start_time: String | Time?
      attr_reader end_time: String | Time?
      attr_reader warmup_candle_cache: Hash[untyped, Array[ohlcv]]

      def resolved_start_time: () -> (String | Time)?
      def resolved_end_time: () -> (String | Time)?
    end
  end
end
