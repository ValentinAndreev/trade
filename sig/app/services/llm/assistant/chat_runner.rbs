module Llm
  module Assistant
    class ChatRunner
      Result: untyped

      def self.suggest_title: (untyped content) -> String

      def initialize: (chat: AiChat, setting: LlmSetting) -> void
      def call: (content: untyped, ?assistant_context: Hash[untyped, untyped]?) -> untyped

      private

      attr_reader chat: AiChat
      attr_reader setting: LlmSetting

      def setting_configured?: () -> bool
      def tool_calling_enabled?: () -> bool
      def maybe_assign_chat_title: (String content) -> void
      def run_tool_agent: (String content_text, Hash[Symbol, untyped] normalized_context, Integer previous_message_id) -> AiMessage?
      def run_plain_chat: (String content_text, Hash[Symbol, untyped] normalized_context) -> AiMessage
      def plain_chat_instructions: (Hash[Symbol, untyped] normalized_context) -> String
      def draft_target_from_context: (Hash[Symbol, untyped] normalized_context) -> Hash[String, untyped]?
      def persist_draft_metadata: (AiMessage message, Hash[String, untyped] draft) -> void
    end
  end
end
