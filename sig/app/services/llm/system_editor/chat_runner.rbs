module Llm
  module SystemEditor
    class ChatRunner
      class Result
        attr_accessor chat: untyped
        attr_accessor assistant_message: untyped
      end

      def initialize: (user: User, chat: untyped, setting: LlmSetting) -> void
      def call: (content: String?, editor_context: Hash[untyped, untyped]) -> Result

      private

      @user: User
      @chat: untyped
      @setting: LlmSetting

      def chat: () -> untyped
      def setting: () -> LlmSetting
      def setting_configured?: () -> bool
      def tool_calling_enabled?: () -> bool
      def maybe_assign_chat_title: (String content) -> void
      def run_tool_agent: (String content_text, Hash[Symbol, untyped] normalized_context) -> untyped
      def run_plain_chat: (String content_text, Hash[Symbol, untyped] normalized_context) -> untyped
      def plain_chat_instructions: (Hash[Symbol, untyped] normalized_context) -> String
      def serialize_response_content: (untyped content) -> String
      def persist_draft_metadata: (untyped message, untyped draft) -> void

      def self.suggest_title: (String? content) -> String
    end
  end
end
