<div data-controller="nav auth" class="h-screen w-full bg-[#1a1a2e] flex flex-col">
  <!-- Nav bar -->
  <div class="flex items-center gap-1 px-4 py-1.5 bg-[#0a0a1e] border-b border-[#2a2a3e] shrink-0">
    <button data-action="click->nav#showMain" data-nav-target="mainBtn"
            class="px-3 py-1.5 rounded text-sm">Main</button>
    <button data-action="click->nav#showGraph" data-nav-target="graphBtn"
            class="px-3 py-1.5 rounded text-sm">Graph</button>
    <div class="ml-auto" data-auth-target="userArea"></div>
  </div>

  <!-- Main page -->
  <div data-nav-target="mainPage" data-controller="main" class="flex-1 overflow-y-auto p-6 space-y-6">
    <section>
      <div class="relative flex items-center gap-2 mb-3">
        <h2 class="text-gray-400 text-sm font-medium uppercase tracking-wider">Crypto</h2>
        <button class="w-5 h-5 flex items-center justify-center rounded text-gray-500 hover:text-green-400 hover:bg-green-400/10 transition-colors text-lg leading-none"
                data-action="click->main#showAddDropdown">+</button>
      </div>
      <div data-main-target="grid" class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3"></div>
    </section>
    <section>
      <div class="relative flex items-center gap-2 mb-3">
        <h2 class="text-gray-400 text-sm font-medium uppercase tracking-wider">World Indices</h2>
        <button class="w-5 h-5 flex items-center justify-center rounded text-gray-500 hover:text-green-400 hover:bg-green-400/10 transition-colors text-lg leading-none"
                data-action="click->main#showAddMarketDropdown" data-category="indices">+</button>
      </div>
      <div data-main-target="indicesGrid" class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-3"></div>
    </section>
    <section>
      <div class="relative flex items-center gap-2 mb-3">
        <h2 class="text-gray-400 text-sm font-medium uppercase tracking-wider">Forex</h2>
        <button class="w-5 h-5 flex items-center justify-center rounded text-gray-500 hover:text-green-400 hover:bg-green-400/10 transition-colors text-lg leading-none"
                data-action="click->main#showAddMarketDropdown" data-category="forex">+</button>
      </div>
      <div data-main-target="forexGrid" class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-3"></div>
    </section>
    <section>
      <div class="relative flex items-center gap-2 mb-3">
        <h2 class="text-gray-400 text-sm font-medium uppercase tracking-wider">Commodities</h2>
        <button class="w-5 h-5 flex items-center justify-center rounded text-gray-500 hover:text-green-400 hover:bg-green-400/10 transition-colors text-lg leading-none"
                data-action="click->main#showAddMarketDropdown" data-category="commodities">+</button>
      </div>
      <div data-main-target="commoditiesGrid" class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-3"></div>
    </section>
  </div>

  <!-- Graph page (existing tabs system, initially hidden) -->
  <div data-nav-target="graphPage" class="hidden flex-1 flex flex-col min-h-0">
    <div data-controller="tabs" class="flex flex-col flex-1 min-h-0">
      <div data-tabs-target="tabBar" class="flex items-center gap-1 px-3 pt-2 bg-[#12122a] border-b border-[#2a2a3e] shrink-0"></div>
      <div class="flex flex-1 min-h-0">
        <div data-tabs-target="panels" class="flex-1 min-w-0 h-full"></div>
        <div data-tabs-target="sidebar" class="w-[27rem] shrink-0 bg-[#12122a] border-l border-[#2a2a3e] overflow-y-auto p-4"></div>
      </div>
    </div>
  </div>
</div>
